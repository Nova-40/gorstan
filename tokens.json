{
  "colors": {
    "background": "#0B0F0E",
    "surface": "#111615",
    "text": "#A7B0A5",
    "console": "#39FF14",
    "zones": {
      "glitch": "#8A2BE2",
      "nexus": "#00E5FF", 
      "elfhame": "#7CFC00",
      "maze": "#FFB300"
    },
    "semantic": {
      "success": "#22C55E",
      "warning": "#F59E0B", 
      "error": "#EF4444",
      "info": "#3B82F6"
    }
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px", 
    "md": "12px",
    "lg": "16px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "48px"
  },
  "radius": {
    "sm": "8px",
    "lg": "14px"
  },
  "targets": {
    "minHit": "40px"
  },
  "animation": {
    "typeSpeed": 40,
    "typeSpeedRange": [35, 45],
    "blinkDuration": 1000,
    "punctuation": {
      "comma": 50,
      "period": 150,
      "exclamation": 150,
      "question": 150,
      "colon": 150,
      "semicolon": 150,
      "ellipsis": 400
    }
  },
  "typography": {
    "fontFamily": {
      "mono": ["'JetBrains Mono'", "'Fira Code'", "'Source Code Pro'", "monospace"]
    }
  },
  "accessibility": {
    "contrastRatio": 4.5,
    "focusRingWidth": "2px"
  }
}
