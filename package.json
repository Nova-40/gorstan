{
  "name": "gorstan-game",
  "version": "3.8.8",
  "description": "Gorstan Text Adventure Game",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:prod": "npm run typecheck && npm run build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "version:bump": "node scripts/bump-version.js",
    "deploy:auto": "npm run version:bump && npm run build && git add . && git commit -m \"Deploy: bump version\" && git push",
    "deploy:manual": "npm run build && vercel --prod",
    "deploy:force": "npm run version:bump && npm run deploy:manual",
    "verify:deployment": "node scripts/verify-deployment.js",
    "e2e": "playwright test",
    "process-modules": "node scripts/process-modules.cjs",
    "add-headers": "node scripts/add-headers.cjs",
    "lint:fix": "npx eslint \"src/**/*.{ts,tsx,js,jsx}\" --fix",
    "lint-safe": "npx eslint \"src/**/*.{ts,tsx,js,jsx}\" --config .eslintrc.safe-autofix.cjs --fix --fix-type problem --fix-type layout",
    "format": "npx prettier \"src/**/*.{ts,tsx,js,jsx}\" --write",
    "verify": "npx tsc --noEmit",
    "smoke": "node scripts/smoke/smoke-test.js",
    "smoke:headful": "HEADFUL=true node scripts/smoke/smoke-test.js",
  "deploy": "npm run build:prod && vercel --prod",
  "deploy:preview": "npm run build && vercel",
  "analyze": "vite build && npx rollup-plugin-visualizer --template treemap --filename reports/bundle.html",
  "analyze:srcmap": "npx source-map-explorer 'dist/assets/*.js' > reports/bundle.txt",
  "deadcode": "npx knip",
  "circulars": "npx madge --circular --extensions ts,tsx src > reports/circulars.md",
  "licenses": "npx license-checker --production --summary > reports/licenses.md",
  "audit": "npm audit --audit-level=moderate",
  "coverage": "vitest run --coverage",
  "a_grade": "bash scripts/a_grade.sh"
  ,"inventory": "node scripts/inventory.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.85.5",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "ajv": "^8.17.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.12",
    "groq-sdk": "^0.30.0",
    "lucide-react": "^0.542.0",
    "prop-types": "^15.8.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1",
    "uuid": "^11.1.0",
    "valtio": "^2.1.7",
    "whatwg-fetch": "^3.6.20",
    "zod": "^4.1.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@babel/core": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@babel/register": "^7.28.3",
    "@hebcal/core": "^5.10.1",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.12",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.8",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "@vitejs/plugin-react": "^5.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "date-fns": "^4.1.0",
    "eslint": "^9.34.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "happy-dom": "^18.0.1",
    "hijri-date": "^0.2.2",
    "jsdom": "^26.1.0",
    "playwright": "^1.55.0",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "rollup-plugin-visualizer": "^6.0.3",
    "solarlunar": "^2.0.7",
    "tailwindcss": "^4.1.12",
    "terser": "^5.43.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vite-plugin-compression": "^0.5.1",
  "vite-tsconfig-paths": "^5.1.4",
  "vitest": "^3.2.4",
  "knip": "^5.63.0",
  "madge": "^8.0.0",
  "license-checker": "^25.0.1",
  "source-map-explorer": "^2.5.3",
  "@axe-core/playwright": "^4.10.2"
  },
  "overrides": {
    "glob": "^10.4.5",
    "inflight": "npm:@isaacs/inflight@^1.0.0",
    "test-exclude": "^7.0.1"
  },
  "engines": {
    "node": "20.x"
  },
  "author": "Geoff Webster",
  "license": "All Rights Reserved"
}
