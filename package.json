{
  "name": "gorstan-layer20",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "node ./scripts/generate-optimized.cjs && vite build",
    "preview": "vite preview",
    "test": "vitest --run",
    "validate:rooms": "vitest __tests__/unit/validateAllRooms.spec.ts --run --passWithNoTests=false",
    "validate:rooms-cli": "vitest __tests__/unit/validateAllRooms.spec.ts --run --passWithNoTests=false",
    "audit:ci": "pnpm run validate:rooms && pnpm run test && pnpm run build",
    "smoke:dev:strict": "node ./scripts/smokeDev.mjs --mode strict --port 5173 --timeoutMs 20000",
    "smoke:dev:autoport": "node ./scripts/smokeDev.mjs --mode autoport --port 5173 --timeoutMs 20000",
    "test:run": "vitest --run"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitejs/plugin-react": "^4.3.0",
    "ajv": "^8.17.1",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "framer-motion": "^12.23.26",
    "globals": "^16.5.0",
    "groq-sdk": "^0.37.0",
    "jsdom": "^27.3.0",
    "lucide-react": "^0.561.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.1",
    "typescript": "^5.4.0",
    "uuid": "^13.0.0",
    "vite": "^7.2.7",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.0.15",
    "zod": "^4.2.0"
  },
  "vitest": {
    "test": {
      "environment": "jsdom"
    }
  }
