{
  "name": "gorstan-game",
  "version": "3.8.8",
  "description": "Gorstan Text Adventure Game",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:prod": "npm run typecheck && npm run build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "jest",
    "test:ui": "jest --watch",
    "analyze": "vite build && npx rollup-plugin-visualizer --json stats.json || true",
    "analyze:html": "vite build && npx rollup-plugin-visualizer --template treemap --open dist/stats.html || true",
    "knip": "knip",
    "tsprune": "ts-prune",
    "version:bump": "node scripts/bump-version.js",
    "deploy:auto": "npm run version:bump && npm run build && git add . && git commit -m \"Deploy: bump version\" && git push",
    "deploy:manual": "npm run build && vercel --prod",
    "deploy:force": "npm run version:bump && npm run deploy:manual",
    "verify:deployment": "node scripts/verify-deployment.js",
    "e2e": "playwright test",
    "process-modules": "node scripts/process-modules.cjs",
    "add-headers": "node scripts/add-headers.cjs",
    "lint:fix": "npx eslint \"src/**/*.{ts,tsx,js,jsx}\" --fix",
    "lint-safe": "npx eslint \"src/**/*.{ts,tsx,js,jsx}\" --config .eslintrc.safe-autofix.cjs --fix --fix-type problem --fix-type layout",
    "format": "npx prettier \"src/**/*.{ts,tsx,js,jsx}\" --write",
    "verify": "npx tsc --noEmit",
    "smoke": "node scripts/smoke/smoke-test.js",
    "smoke:headful": "HEADFUL=true node scripts/smoke/smoke-test.js",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "deploy": "npm run build:prod && vercel --prod",
    "deploy:preview": "npm run build && vercel",
    "sbom": "cyclonedx-npm --output-format JSON --output-file sbom.json --package-lock-only",
    "backup:local": "node ./scripts/backup-local.mjs",
    "backup:verify": "node ./scripts/backup-verify.mjs",
    "backup:restore-test": "node ./scripts/backup-restore-test.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.84.2",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "ajv": "^8.17.1",
    "archiver": "^7.0.1",
    "framer-motion": "^12.23.12",
    "globby": "^14.1.0",
    "groq-sdk": "^0.30.0",
    "lucide-react": "^0.539.0",
    "prop-types": "^15.8.1",
    "uuid": "^11.1.0",
    "valtio": "^2.1.5",
    "zod": "^4.0.17",
    "zustand": "^5.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@babel/register": "^7.27.1",
    "@cyclonedx/cyclonedx-npm": "^4.0.0",
    "@hebcal/core": "^5.10.1",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.16",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.2.1",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "date-fns": "^4.1.0",
    "eslint": "^9.33.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "hijri-date": "^0.2.2",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "knip": "^5.62.0",
    "playwright": "^1.54.2",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "rollup-plugin-visualizer": "^6.0.3",
    "shx": "^0.3.4",
    "solarlunar": "^2.0.7",
    "tailwindcss": "^4.1.11",
    "terser": "^5.43.1",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "ts-prune": "^0.10.3",
    "typescript": "^5.9.2",
    "vite": "^7.1.2",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-inspect": "^11.3.2",
    "vitest": "^3.2.4",
    "zx": "^8.2.7"
  },
  "overrides": {
    "glob": "^10.4.5",
    "inflight": "npm:@isaacs/inflight@^1.0.0",
    "test-exclude": "^7.0.1"
  },
  "engines": {
    "node": "20.x"
  },
  "author": "Geoff Webster",
  "license": "All Rights Reserved"
}
