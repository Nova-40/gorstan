  Gorstan – Copyright © 2025 Geoff Webster. All Rights Reserved.
  
  Performance Dashboard Component - Phase 10.1
  UI for monitoring and controlling performance optimization
*/

import React, { useState, useEffect } from 'react';
import { 
  Monitor, 
  Settings, 
  Zap, 
  MemoryStick, 
  Cpu, 
  AlertTriangle, 
  CheckCircle, 
  TrendingDown,
  TrendingUp,
  RefreshCw,
  X
} from 'lucide-react';
import usePerformanceManager, { usePerformanceMonitoring, useDeviceCapabilities } from '../hooks/usePerformanceManager';
import PerformanceManager from '../services/PerformanceManager';
import '../styles/PerformanceDashboard.css';

interface PerformanceDashboardProps {
  isOpen: boolean;
  onClose: () => void;
}

const PerformanceDashboard: React.FC<PerformanceDashboardProps> = ({ isOpen, onClose }) => {
  const [state, actions] = usePerformanceManager();
  const { alerts, summary, clearAlerts, refreshSummary } = usePerformanceMonitoring();
  const { capabilities } = useDeviceCapabilities();
  const [selectedTab, setSelectedTab] = useState<'overview' | 'settings' | 'profiles' | 'alerts'>('overview');
  const [showAdvanced, setShowAdvanced] = useState(false);

  // Auto-refresh summary
  useEffect(() => {
    if (isOpen) {
      const interval = setInterval(refreshSummary, 5000);
      return () => clearInterval(interval);
    }
  }, [isOpen, refreshSummary]);

  if (!isOpen) return null;

  const formatMemory = (mb: number) => {
    if (mb < 1024) return `${Math.round(mb)}MB`;
    return `${(mb / 1024).toFixed(1)}GB`;
  };

  const getPerformanceColor = (value: number, thresholds: [number, number]) => {
    if (value >= thresholds[1]) return 'text-green-500';
    if (value >= thresholds[0]) return 'text-yellow-500';
    return 'text-red-500';
  };

  const getTierIcon = (tier: string) => {
    switch (tier) {
      case 'high': return <TrendingUp className="text-green-500" size={16} />;
      case 'medium': return <Zap className="text-yellow-500" size={16} />;
      case 'low': return <TrendingDown className="text-red-500" size={16} />;
      default: return <Monitor className="text-gray-500" size={16} />;
    }
  };

  const profiles = PerformanceManager.getInstance().getOptimizationProfiles();

  return (
    <div className="modal-overlay performance-dashboard-overlay">
      <div className="modal-content performance-dashboard">
        <div className="modal-header">
          <h2 className="modal-title">
            <Monitor className="modal-icon" />
            Performance Dashboard
          </h2>
          <button className="modal-close" onClick={onClose}>
            <X size={20} />
          </button>
        </div>

        <div className="performance-tabs">
          <button 
            className={`tab ${selectedTab === 'overview' ? 'active' : ''}`}
            onClick={() => setSelectedTab('overview')}
          >
            <Monitor size={16} />
            Overview
          </button>
          <button 
            className={`tab ${selectedTab === 'settings' ? 'active' : ''}`}
            onClick={() => setSelectedTab('settings')}
          >
            <Settings size={16} />
            Settings
          </button>
          <button 
            className={`tab ${selectedTab === 'profiles' ? 'active' : ''}`}
            onClick={() => setSelectedTab('profiles')}
          >
            <Zap size={16} />
            Profiles
          </button>
          <button 
            className={`tab ${selectedTab === 'alerts' ? 'active' : ''}`}
            onClick={() => setSelectedTab('alerts')}
          >
            <AlertTriangle size={16} />
            Alerts {alerts.length > 0 && <span className="alert-badge">{alerts.length}</span>}
          </button>
        </div>

        <div className="performance-content">
          {selectedTab === 'overview' && (
            <div className="overview-tab">
              <div className="performance-summary">
                <div className="summary-card">
                  <div className="card-header">
                    <Monitor size={20} />
                    <span>Performance</span>
                    <button onClick={refreshSummary} className="refresh-btn">
                      <RefreshCw size={16} />
                    </button>
                  </div>
                  
                  {summary ? (
                    <div className="metrics-grid">
                      <div className="metric">
                        <span className="metric-label">FPS</span>
                        <span className={`metric-value ${getPerformanceColor(summary.currentFPS, [30, 45])}`}>
                          {Math.round(summary.currentFPS)}
                        </span>
                      </div>
                      <div className="metric">
                        <span className="metric-label">Memory</span>
                        <span className="metric-value">
                          {formatMemory(summary.memoryUsage)}
                        </span>
                      </div>
                      <div className="metric">
                        <span className="metric-label">Tier</span>
                        <span className="metric-value">
                          {getTierIcon(summary.performanceTier)}
                          {summary.performanceTier}
                        </span>
                      </div>
                      <div className="metric">
                        <span className="metric-label">Profile</span>
                        <span className="metric-value">
                          {summary.activeProfile}
                        </span>
                      </div>
                    </div>
                  ) : (
                    <div className="loading">Loading performance data...</div>
                  )}
                </div>

                {capabilities && (
                  <div className="device-info-card">
                    <div className="card-header">
                      <Cpu size={20} />
                      <span>Device Information</span>
                    </div>
                    <div className="device-specs">
                      <div className="spec-row">
                        <span>Platform:</span>
                        <span>{capabilities.platform}</span>
                      </div>
                      <div className="spec-row">
                        <span>CPU Cores:</span>
                        <span>{capabilities.cpuCores}</span>
                      </div>
                      <div className="spec-row">
                        <span>Memory:</span>
                        <span>{capabilities.memoryGB}GB</span>
                      </div>
                      <div className="spec-row">
                        <span>GPU Tier:</span>
                        <span>{capabilities.gpuTier}</span>
                      </div>
                      <div className="spec-row">
                        <span>Screen:</span>
                        <span>{capabilities.screenSize.width}×{capabilities.screenSize.height}</span>
                      </div>
                      <div className="spec-row">
                        <span>WebGL:</span>
                        <span>{capabilities.supportsWebGL ? '✓' : '✗'}</span>
                      </div>
                    </div>
                  </div>
                )}
              </div>

              <div className="quick-actions">
                <button 
                  onClick={actions.forceGarbageCollection}
                  className="action-btn"
                  title="Force garbage collection to free memory"
                >
                  <MemoryStick size={16} />
                  Free Memory
                </button>
                
                <button 
                  onClick={() => actions.applyProfile('Battery Saver')}
                  className="action-btn"
                  title="Switch to battery saver mode"
                >
                  <TrendingDown size={16} />
                  Battery Mode
                </button>
                
                <button 
                  onClick={() => actions.applyProfile('Ultra Performance')}
                  className="action-btn"
                  title="Switch to maximum performance"
                >
                  <TrendingUp size={16} />
                  Max Performance
                </button>
              </div>
            </div>
          )}

          {selectedTab === 'settings' && state.settings && (
            <div className="settings-tab">
              <div className="settings-section">
                <h3>Visual Quality</h3>
                <div className="setting-group">
                  <label>Animation Quality</label>
                  <select 
                    value={state.settings.animationQuality}
                    onChange={(e) => actions.updateSettings({ 
                      animationQuality: e.target.value as 'low' | 'medium' | 'high' 
                    })}
                  >
                    <option value="low">Low</option>
                    <option value="medium">Medium</option>
                    <option value="high">High</option>
                  </select>
                </div>
                
                <div className="setting-group">
                  <label>Texture Quality</label>
                  <select 
                    value={state.settings.textureQuality}
                    onChange={(e) => actions.updateSettings({ 
                      textureQuality: e.target.value as 'low' | 'medium' | 'high' 
                    })}
                  >
                    <option value="low">Low</option>
                    <option value="medium">Medium</option>
                    <option value="high">High</option>
                  </select>
                </div>
                
                <div className="setting-group">
                  <label>
                    <input 
                      type="checkbox"
                      checked={state.settings.particleEffects}
                      onChange={(e) => actions.updateSettings({ 
                        particleEffects: e.target.checked 
                      })}
                    />
                    Particle Effects
                  </label>
                </div>
              </div>

              <div className="settings-section">
                <h3>Memory Management</h3>
                <div className="setting-group">
                  <label>Memory Target: {formatMemory(state.settings.memoryTargetMB)}</label>
                  <input 
                    type="range"
                    min="100"
                    max="1000"
                    step="50"
                    value={state.settings.memoryTargetMB}
                    onChange={(e) => actions.updateSettings({ 
                      memoryTargetMB: parseInt(e.target.value) 
                    })}
                  />
                </div>
                
                <div className="setting-group">
                  <label>Max Cached Assets: {state.settings.maxCachedAssets}</label>
                  <input 
                    type="range"
                    min="20"
                    max="200"
                    step="10"
                    value={state.settings.maxCachedAssets}
                    onChange={(e) => actions.updateSettings({ 
                      maxCachedAssets: parseInt(e.target.value) 
                    })}
                  />
                </div>
                
                <div className="setting-group">
                  <label>Preload Distance: {state.settings.preloadDistance} rooms</label>
                  <input 
                    type="range"
                    min="0"
                    max="5"
                    step="1"
                    value={state.settings.preloadDistance}
                    onChange={(e) => actions.updateSettings({ 
                      preloadDistance: parseInt(e.target.value) 
                    })}
                  />
                </div>
              </div>

              <div className="settings-section">
                <h3>Game Features</h3>
                <div className="setting-group">
                  <label>Auto-save Frequency: {state.settings.autoSaveFrequency}s</label>
                  <input 
                    type="range"
                    min="30"
                    max="300"
                    step="30"
                    value={state.settings.autoSaveFrequency}
                    onChange={(e) => actions.updateSettings({ 
                      autoSaveFrequency: parseInt(e.target.value) 
                    })}
                  />
                </div>
                
                <div className="setting-group">
                  <label>
                    <input 
                      type="checkbox"
                      checked={state.settings.backgroundProcessing}
                      onChange={(e) => actions.updateSettings({ 
                        backgroundProcessing: e.target.checked 
                      })}
                    />
                    Background Processing
                  </label>
                </div>
                
                <div className="setting-group">
                  <label>
                    <input 
                      type="checkbox"
                      checked={state.settings.prefetchEnabled}
                      onChange={(e) => actions.updateSettings({ 
                        prefetchEnabled: e.target.checked 
                      })}
                    />
                    Prefetch Assets
                  </label>
                </div>
              </div>

              <div className="advanced-toggle">
                <button 
                  onClick={() => setShowAdvanced(!showAdvanced)}
                  className="toggle-btn"
                >
                  {showAdvanced ? 'Hide' : 'Show'} Advanced Settings
                </button>
              </div>

              {showAdvanced && (
                <div className="settings-section">
                  <h3>Advanced</h3>
                  <div className="setting-group">
                    <label>GC Threshold: {(state.settings.garbageCollectionThreshold * 100).toFixed(0)}%</label>
                    <input 
                      type="range"
                      min="0.5"
                      max="1.0"
                      step="0.1"
                      value={state.settings.garbageCollectionThreshold}
                      onChange={(e) => actions.updateSettings({ 
                        garbageCollectionThreshold: parseFloat(e.target.value) 
                      })}
                    />
                  </div>
                  
                  <div className="setting-group">
                    <label>Resource Pool Size: {state.settings.resourcePoolSize}</label>
                    <input 
                      type="range"
                      min="10"
                      max="100"
                      step="5"
                      value={state.settings.resourcePoolSize}
                      onChange={(e) => actions.updateSettings({ 
                        resourcePoolSize: parseInt(e.target.value) 
                      })}
                    />
                  </div>
                </div>
              )}
            </div>
          )}

          {selectedTab === 'profiles' && (
            <div className="profiles-tab">
              <div className="profiles-grid">
                {profiles.map((profile) => (
                  <div 
                    key={profile.name}
                    className={`profile-card ${summary?.activeProfile === profile.name ? 'active' : ''}`}
                  >
                    <div className="profile-header">
                      <h4>{profile.name}</h4>
                      {summary?.activeProfile === profile.name && (
                        <CheckCircle size={16} className="text-green-500" />
                      )}
                    </div>
                    <p className="profile-description">{profile.description}</p>
                    
                    <div className="profile-targets">
                      <div className="target-item">
                        <span>Performance:</span>
                        <span>{profile.deviceTargets.minPerformanceTier}+</span>
                      </div>
                      <div className="target-item">
                        <span>Platforms:</span>
                        <span>{profile.deviceTargets.platforms.join(', ')}</span>
                      </div>
                      <div className="target-item">
                        <span>Memory:</span>
                        <span>{profile.deviceTargets.memoryRange[0]}-{profile.deviceTargets.memoryRange[1]}GB</span>
                      </div>
                    </div>
                    
                    <button 
                      onClick={() => actions.applyProfile(profile.name)}
                      className={`apply-profile-btn ${summary?.activeProfile === profile.name ? 'active' : ''}`}
                      disabled={summary?.activeProfile === profile.name}
                    >
                      {summary?.activeProfile === profile.name ? 'Active' : 'Apply'}
                    </button>
                  </div>
                ))}
              </div>
            </div>
          )}

          {selectedTab === 'alerts' && (
            <div className="alerts-tab">
              <div className="alerts-header">
                <h3>Performance Alerts</h3>
                {alerts.length > 0 && (
                  <button onClick={clearAlerts} className="clear-alerts-btn">
                    Clear All
                  </button>
                )}
              </div>
              
              {alerts.length === 0 ? (
                <div className="no-alerts">
                  <CheckCircle size={48} className="text-green-500" />
                  <p>No performance issues detected!</p>
                  <p className="text-muted">Your game is running smoothly.</p>
                </div>
              ) : (
                <div className="alerts-list">
                  {alerts.map((alert, index) => (
                    <div key={index} className={`alert-item ${alert.severity}`}>
                      <div className="alert-header">
                        <AlertTriangle size={16} />
                        <span className="alert-type">{alert.type.toUpperCase()}</span>
                        <span className="alert-severity">{alert.severity}</span>
                      </div>
                      <p className="alert-message">{alert.message}</p>
                      {alert.suggestions.length > 0 && (
                        <div className="alert-suggestions">
                          <strong>Suggestions:</strong>
                          <ul>
                            {alert.suggestions.map((suggestion, idx) => (
                              <li key={idx}>{suggestion}</li>
                            ))}
                          </ul>
                        </div>
                      )}
                      <div className="alert-timestamp">
                        {new Date(alert.timestamp).toLocaleTimeString()}
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  );
}; 
                     summary.status === 'warning' ? 'text-yellow-400' : 'text-red-400';

  return (
    <div className="fixed inset-0 bg-black bg-opacity-80 flex items-center justify-center z-50">
      <div className="bg-gray-900 text-white p-6 rounded-lg max-w-4xl w-full max-h-[90vh] overflow-y-auto">
        {/* Header */}
        <div className="flex justify-between items-center mb-6">
          <h2 className="text-2xl font-bold text-blue-400">Performance Dashboard</h2>
          <div className="flex gap-2">
            <button
              onClick={generateReport}
              className="px-4 py-2 bg-blue-600 hover:bg-blue-700 rounded text-sm"
            >
              Export Report
            </button>
            <button
              onClick={onClose}
              className="px-4 py-2 bg-gray-600 hover:bg-gray-700 rounded text-sm"
            >
              Close
            </button>
          </div>
        </div>

        {/* Status Overview */}
        <div className="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
          <div className="bg-gray-800 p-4 rounded">
            <h3 className="text-lg font-semibold mb-2">Overall Status</h3>
            <div className={`text-2xl font-bold ${statusColor}`}>
              {summary.status.toUpperCase()}
            </div>
            {summary.issues.length > 0 && (
              <div className="text-sm text-gray-400 mt-2">
                {summary.issues.length} issue(s) detected
              </div>
            )}
          </div>

          <div className="bg-gray-800 p-4 rounded">
            <h3 className="text-lg font-semibold mb-2">Frame Rate</h3>
            <div className={`text-2xl font-bold ${metrics.frameRate < 30 ? 'text-red-400' : 'text-green-400'}`}>
              {metrics.frameRate} FPS
            </div>
            <div className="text-sm text-gray-400">Target: 60 FPS</div>
          </div>

          <div className="bg-gray-800 p-4 rounded">
            <h3 className="text-lg font-semibold mb-2">Memory Usage</h3>
            <div className={`text-2xl font-bold ${metrics.memoryUsage > 100 ? 'text-red-400' : 'text-green-400'}`}>
              {metrics.memoryUsage} MB
            </div>
            <div className="text-sm text-gray-400">Limit: 100 MB</div>
          </div>
        </div>

        {/* Detailed Metrics */}
        <div className="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
          {/* Render Performance */}
          <div className="bg-gray-800 p-4 rounded">
            <h3 className="text-lg font-semibold mb-3">Render Performance</h3>
            <div className="space-y-2 text-sm">
              <div className="flex justify-between">
                <span>Render Time:</span>
                <span className={metrics.renderTime > 16.67 ? 'text-red-400' : 'text-green-400'}>
                  {metrics.renderTime.toFixed(2)}ms
                </span>
              </div>
              <div className="flex justify-between">
                <span>Animation Frame Time:</span>
                <span>{metrics.animationFrameTime.toFixed(2)}ms</span>
              </div>
              <div className="flex justify-between">
                <span>NPC Processing:</span>
                <span className={metrics.npcProcessingTime > 10 ? 'text-red-400' : 'text-green-400'}>
                  {metrics.npcProcessingTime.toFixed(2)}ms
                </span>
              </div>
            </div>
          </div>

          {/* State Optimization */}
          <div className="bg-gray-800 p-4 rounded">
            <h3 className="text-lg font-semibold mb-3">State Optimization</h3>
            <div className="space-y-2 text-sm">
              <div className="flex justify-between">
                <span>State Size:</span>
                <span>{(optimizerMetrics.stateSize / 1024).toFixed(1)} KB</span>
              </div>
              <div className="flex justify-between">
                <span>Compression Ratio:</span>
                <span>{optimizerMetrics.compressionRatio.toFixed(2)}x</span>
              </div>
              <div className="flex justify-between">
                <span>Cleanups:</span>
                <span>{optimizerMetrics.cleanupCount}</span>
              </div>
              <div className="flex justify-between">
                <span>Last Optimization:</span>
                <span>
                  {optimizerMetrics.lastOptimization 
                    ? new Date(optimizerMetrics.lastOptimization).toLocaleTimeString()
                    : 'Never'
                  }
                </span>
              </div>
            </div>
          </div>

          {/* System Info */}
          <div className="bg-gray-800 p-4 rounded">
            <h3 className="text-lg font-semibold mb-3">System Info</h3>
            <div className="space-y-2 text-sm">
              <div className="flex justify-between">
                <span>User Agent:</span>
                <span className="truncate max-w-40" title={navigator.userAgent}>
                  {navigator.userAgent.split(' ')[0]}
                </span>
              </div>
              <div className="flex justify-between">
                <span>Viewport:</span>
                <span>{window.innerWidth}x{window.innerHeight}</span>
              </div>
              <div className="flex justify-between">
                <span>Device Pixel Ratio:</span>
                <span>{window.devicePixelRatio || 1}</span>
              </div>
              <div className="flex justify-between">
                <span>Online:</span>
                <span className={navigator.onLine ? 'text-green-400' : 'text-red-400'}>
                  {navigator.onLine ? 'Yes' : 'No'}
                </span>
              </div>
            </div>
          </div>
        </div>

        {/* Warnings */}
        {warnings.length > 0 && (
          <div className="bg-red-900 bg-opacity-20 border border-red-400 p-4 rounded mb-6">
            <div className="flex justify-between items-center mb-2">
              <h3 className="text-lg font-semibold text-red-400">Performance Warnings</h3>
              <button
                onClick={clearWarnings}
                className="px-3 py-1 bg-red-600 hover:bg-red-700 rounded text-sm"
              >
                Clear
              </button>
            </div>
            <div className="space-y-1 text-sm max-h-32 overflow-y-auto">
              {warnings.map((warning, index) => (
                <div key={index} className="text-red-300">
                  {warning}
                </div>
              ))}
            </div>
          </div>
        )}

        {/* Quick Actions */}
        <div className="flex flex-wrap gap-2">
          <button
            onClick={() => window.location.reload()}
            className="px-4 py-2 bg-orange-600 hover:bg-orange-700 rounded text-sm"
          >
            Reload Page
          </button>
          <button
            onClick={() => {
              if ('gc' in window) {
                (window as any).gc();
                alert('Garbage collection triggered');
              } else {
                alert('Garbage collection not available');
              }
            }}
            className="px-4 py-2 bg-purple-600 hover:bg-purple-700 rounded text-sm"
          >
            Force GC
          </button>
          <button
            onClick={() => {
              localStorage.clear();
              sessionStorage.clear();
              alert('Storage cleared');
            }}
            className="px-4 py-2 bg-red-600 hover:bg-red-700 rounded text-sm"
          >
            Clear Storage
          </button>
        </div>
      </div>
    </div>
  );
};

export default PerformanceDashboard;
